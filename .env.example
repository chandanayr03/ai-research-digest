# Get your Groq API key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Create a bot via @BotFather on Telegram, paste the token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Send a message to your bot, then visit:
# https://api.telegram.org/bot<TOKEN>/getUpdates
# Find "chat":{"id":XXXXXXX} and paste that number
TELEGRAM_CHAT_ID=your_chat_id_here

# (Optional) Restrict feedback votes to your Telegram user ID only
# ADMIN_USER_ID=your_telegram_user_id

# ── Agent Settings (defaults are fine) ──
# GROQ_MODEL=llama-3.1-8b-instant
# PAPERS_PER_SOURCE=5
# TOP_K=3
# LOOKBACK_DAYS=2
